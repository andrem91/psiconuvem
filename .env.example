# ========================================
# DATABASE (Docker Local)
# ========================================
POSTGRES_DB=psiconuvem
POSTGRES_USER=psicodev
POSTGRES_PASSWORD=TROCAR_POR_SENHA_FORTE_AQUI

# ========================================
# SPRING BOOT
# ========================================
SPRING_PROFILE=dev  # dev | prod

# ========================================
# JWT (Segurança)
# ========================================
# GERE UM SECRET FORTE:
# Linux/Mac: openssl rand -base64 64
# Online: https://generate-secret.vercel.app/64
JWT_SECRET=TROCAR_POR_SECRET_GERADO_COM_64_CARACTERES_MINIMO
JWT_EXPIRATION_HOURS=24

# ========================================
# AWS (Desenvolvimento - LocalStack)
# ========================================
# Em DEV, deixe como 'test' (LocalStack aceita qualquer coisa)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566

# ========================================
# AWS (Produção - AWS Real)
# ========================================
# Em PROD, remova os valores acima e use:
# AWS_ACCESS_KEY_ID=sua-chave-real-aqui
# AWS_SECRET_ACCESS_KEY=sua-secret-real-aqui
# AWS_REGION=sa-east-1
# AWS_ENDPOINT=  (deixe vazio para usar AWS real)

# ========================================
# S3 BUCKETS
# ========================================
S3_BUCKET_PRONTUARIOS=psiconuvem-prontuarios
S3_BUCKET_PUBLICO=psiconuvem-public-assets
S3_BUCKET_BACKUPS=psiconuvem-backups

# ========================================
# ASAAS (Pagamentos) - Sprint 4
# ========================================
# Criar conta: https://www.asaas.com/
# ASAAS_API_KEY=
# ASAAS_ENVIRONMENT=sandbox  # sandbox | production
# ASAAS_WEBHOOK_SECRET=

# ========================================
# LIVEKIT (Vídeo) - Sprint 5
# ========================================
# Criar conta: https://cloud.livekit.io/
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://psiconuvem.livekit.cloud

# ========================================
# EMAIL (Opcional)
# ========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
